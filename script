        local icon = createLabel(btn, "+", Enum.TextXAlignment.Right, Enum.Font.GothamBold, 16, C.Accent)
        icon.Size = UDim2.new(0, 20, 1, 0); icon.Position = UDim2.new(1, -25, 0, 0)

        local listContainer = Instance.new("Frame")
        listContainer.BackgroundColor3 = C.ElementBG
        listContainer.BorderColor3 = C.Accent
        listContainer.BorderSizePixel = 1
        listContainer.Visible = false
        listContainer.ClipsDescendants = true
        listContainer.ZIndex = 100
        listContainer.Parent = Gui

        local listScroll = Instance.new("ScrollingFrame")
        listScroll.Size = UDim2.new(1, 0, 1, 0)
        listScroll.BackgroundTransparency = 1
        listScroll.ScrollBarThickness = 3
        listScroll.ScrollBarImageColor3 = C.Accent
        listScroll.ZIndex = 101
        listScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
        listScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
        listScroll.Parent = listContainer
        
        local dList = Instance.new("UIListLayout")
        dList.SortOrder = Enum.SortOrder.LayoutOrder
        dList.Padding = UDim.new(0, 2)
        dList.Parent = listScroll

        local pad = Instance.new("UIPadding"); pad.PaddingLeft = UDim.new(0, 2); pad.PaddingRight = UDim.new(0, 2); pad.PaddingTop = UDim.new(0, 2); pad.PaddingBottom = UDim.new(0, 2); pad.Parent = listScroll

        btn.Activated:Connect(function()
            local willOpen = not listContainer.Visible
            if activeDropdown and activeDropdown ~= listContainer then activeDropdown.Visible = false end
            
            icon.Text = willOpen and "-" or "+"
            listContainer.Visible = willOpen
            activeDropdown = willOpen and listContainer or nil

            if willOpen then
                _G.ActiveDropdownButton = btn
                _G.ActiveDropdownContainer = listContainer
                local itemHeight = 35; local listPadding = 4; local maxHeight = 150
                local totalHeight = (#list * itemHeight) + ((#list - 1) * dList.Padding.Offset) + listPadding
                local finalHeight = math.min(totalHeight, maxHeight)

                listContainer.Size = UDim2.new(0, btn.AbsoluteSize.X, 0, finalHeight)
                local xPos = btn.AbsolutePosition.X
                local yPos = btn.AbsolutePosition.Y + btn.AbsoluteSize.Y
                if (btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + finalHeight) > Gui.AbsoluteSize.Y then
                    yPos = btn.AbsolutePosition.Y - finalHeight
                end
                listContainer.Position = UDim2.new(0, xPos, 0, yPos)
            else
                if _G.ActiveDropdownContainer == listContainer then
                    _G.ActiveDropdownContainer = nil; _G.ActiveDropdownButton = nil
                end
            end
        end)
        
        Page:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
            if listContainer.Visible then 
                listContainer.Visible = false; activeDropdown = nil; icon.Text = "+" 
                if _G.ActiveDropdownContainer == listContainer then _G.ActiveDropdownContainer = nil; _G.ActiveDropdownButton = nil end
            end
        end)
        
        local function updateLabel()
            local count = 0; for k, v in pairs(selected) do if v then count = count + 1 end end; lbl.Text = title .. " (" .. count .. ")"
        end
        
        for _, item in ipairs(list) do
            local iBtn = Instance.new("TextButton")
            iBtn.Size = UDim2.new(1, 0, 0, 35)
            iBtn.BackgroundColor3 = C.ElementBG
            iBtn.Text = "  " .. item .. (selected[item] and " [ON]" or ""); iBtn.TextColor3 = selected[item] and C.Accent or C.Muted; iBtn.Font = Enum.Font.Gotham; iBtn.TextSize = 13; iBtn.TextXAlignment = Enum.TextXAlignment.Left; iBtn.ZIndex = 102; iBtn.BorderSizePixel = 0; iBtn.AutoButtonColor = false; iBtn.Parent = listScroll
            iBtn.MouseEnter:Connect(function() iBtn.BackgroundColor3 = C.ElementHover end)
            iBtn.MouseLeave:Connect(function() iBtn.BackgroundColor3 = C.ElementBG end)
            
            iBtn.Activated:Connect(function()
                selected[item] = not selected[item]; iBtn.Text = "  " .. item .. (selected[item] and " [ON]" or ""); iBtn.TextColor3 = selected[item] and C.Accent or C.Muted; updateLabel(); if callback then callback(selected) end
            end)
        end
