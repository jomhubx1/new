        if state then
            local s, d = pcall(function() return HttpService:JSONEncode(S) end)
            if s then pcall(writefile, "JomHUB_Configs/"..name..".json", d) end
            pcall(writefile, "JomHUB_Configs/JomHubMobile_autoload.txt", name)
        else
            pcall(writefile, "JomHUB_Configs/JomHubMobile_autoload.txt", "")
        end
    end
end

