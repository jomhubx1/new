                local lastAcc = char:GetAttribute("LastQuestAccept") or 0
                if tick() - lastAcc > 1 then
                    char:SetAttribute("LastQuestAccept", tick())
                    if QuestAccept then pcall(function() QuestAccept:FireServer(targetQuest) end) end
                end
            end
            
            local lastComp = char:GetAttribute("LastQuestComplete") or 0
            if tick() - lastComp > 2 then
                char:SetAttribute("LastQuestComplete", tick())
                if QuestComplete then pcall(function() QuestComplete:FireServer(targetQuest) end) end
            end

        elseif S.AutoFarmActive then
            targetMob = S.selectedMob
        elseif S.AutoBossActive then
            targetMob = S.selectedBoss
        elseif S.AutoAllBossActive then
            local NPCsFolder = Workspace:FindFirstChild("NPCs")
            local foundPhysicalBoss = false
            
            -- 1. Prioritize ANY physical boss already loaded in workspace.NPCs
            if NPCsFolder then
                for _, npc in ipairs(NPCsFolder:GetChildren()) do
                    local hum = npc:FindFirstChild("Humanoid")
                    if hum and hum.Health > 0 then
                        local npcName = npc.Name:gsub("%d+$", "")
                        npcName = npcName:gsub("_.*", "")
                        local cleanNPC = string.lower(string.gsub(npcName, "%s+", ""))
                        
                        for _, bName in ipairs(MAJOR_BOSSES) do
                            local cleanTarget = string.lower(string.gsub(bName, "%s+", ""))
                            local strippedTarget = string.gsub(cleanTarget, "boss", "")
                            
                            if cleanNPC == cleanTarget or cleanNPC == strippedTarget then
                                targetMob = bName
                                foundPhysicalBoss = true
                                break
                            end
                        end
                    end
                    if foundPhysicalBoss then break end
                end
            end
            
            if not targetMob then
                if S.autoHopAllBosses then
                    if not char:GetAttribute("HopDelayStarted") then
                        char:SetAttribute("HopDelayStarted", tick())
                    end
                    if tick() - char:GetAttribute("HopDelayStarted") > 5 then
                        print("[JOMHUB] All bosses dead. Hopping server...")
                        ServerHop()
                        task.wait(10)
                    end
                end
            else
                char:SetAttribute("HopDelayStarted", nil)
            end
        elseif S.autoSummonPity or S.autoHopPity then
            local pityCount = _G.JomHub_BossPity or 0
            local targetBossName = ""
            local shouldHop = false
            
            if pityCount >= 24 then
                if not S.pitySummonBoss or S.pitySummonBoss == "None" then
                    targetBossName = "None"
                else
                    targetBossName = S.pitySummonBoss
                end
            else
                if S.autoHopPity then
                    local aliveWorldBosses = {}
                    local WORLDBOSSES = {"GojoBoss", "YujiBoss", "YamatoBoss", "AlucardBoss", "StrongestShinobiBoss", "JinwooBoss", "SukunaBoss", "AizenBoss"}
                    for _, b in ipairs(WORLDBOSSES) do
                        if checkBossAlive(b) then table.insert(aliveWorldBosses, b) end
                    end

                    if #aliveWorldBosses > 0 then
                        local selected = aliveWorldBosses[1]
                        for _, b in ipairs(aliveWorldBosses) do
                            if b ~= S.pitySummonBoss then selected = b; break end
                        end
                        targetBossName = selected
                    else
                        shouldHop = true
                    end
                else
                    local builderList = {}
                    for k, v in pairs(S.pityBuilderBosses or {}) do if v then table.insert(builderList, k) end end
                    table.sort(builderList)
                    if #builderList == 0 then builderList = {"SaberBoss"} end
                    
                    local foundAlive = false
                    for _, b in ipairs(builderList) do
                        if checkBossAlive(b) then targetBossName = b; foundAlive = true; break end
                    end
                    if not foundAlive then
                        local cIdx = char:GetAttribute("PityBuilderIdx") or 1
                        if cIdx > #builderList then cIdx = 1; char:SetAttribute("PityBuilderIdx", 1) end
                        targetBossName = builderList[cIdx]
                    end
                end
            end
            
            targetMob = targetBossName
            
            if shouldHop then
                if not char:GetAttribute("PityHopDelay") then char:SetAttribute("PityHopDelay", tick()) end
                if tick() - char:GetAttribute("PityHopDelay") > 5 then
                    print("[JOMHUB] AUTO HOP PITY: No world bosses alive. Hopping...")
                    ServerHop()
                    task.wait(10)
                end
                continue
            else
                char:SetAttribute("PityHopDelay", nil)
            end
        elseif S.autoFarmItems then
            local activeItems = {}
            for k, v in pairs(S.farmSecret or {}) do if v then table.insert(activeItems, k) end end
            for k, v in pairs(S.farmMythical or {}) do if v then table.insert(activeItems, k) end end
            for k, v in pairs(S.farmLegendary or {}) do if v then table.insert(activeItems, k) end end
            for k, v in pairs(S.farmEpic or {}) do if v then table.insert(activeItems, k) end end
            for k, v in pairs(S.farmRare or {}) do if v then table.insert(activeItems, k) end end
            for k, v in pairs(S.farmCommon or {}) do if v then table.insert(activeItems, k) end end

            table.sort(activeItems)
            if #activeItems > 0 then
                local cIdx = char:GetAttribute("ItemFarmIdx") or 1
                if cIdx > #activeItems then cIdx = 1; char:SetAttribute("ItemFarmIdx", cIdx) end
                
                local currentItem = activeItems[cIdx]
                local targetLogic = ITEM_TARGETS[currentItem]
                
                local startTime = char:GetAttribute("ItemFarmTime")
                if not startTime then 
                    startTime = tick()
                    char:SetAttribute("ItemFarmTime", startTime)
                end
                
                if tick() - startTime >= S.itemFarmDuration then
                    char:SetAttribute("ItemFarmIdx", cIdx + 1)
                    char:SetAttribute("ItemFarmTime", tick())
                    task.wait(1)
                    continue
                end
                
                if targetLogic == "AutoLevel" then
                    local myLevel = getCurrentLevel()
                    local bestTier = PROGRESSION_MAP[1]
                    for _, tier in ipairs(PROGRESSION_MAP) do
                        if myLevel >= tier.Level then bestTier = tier else break end
                    end
                    targetMob = bestTier.Mob
                elseif targetLogic == "AllBosses" then
                    for _, bName in ipairs(MAJOR_BOSSES) do
                        if checkBossAlive(bName) then targetMob = bName; break end
                    end
                    if not targetMob then
                        char:SetAttribute("ItemFarmIdx", cIdx + 1)
                        char:SetAttribute("ItemFarmTime", tick())
                    end
                else
                    if string.find(string.lower(targetLogic), "boss") then
                        if checkBossAlive(targetLogic) then targetMob = targetLogic
                        else char:SetAttribute("ItemFarmIdx", cIdx + 1); char:SetAttribute("ItemFarmTime", tick()) end
                    else
                        targetMob = targetLogic
                    end
                end
            end
        elseif S.autoFarmTitle and S.selectedTitle ~= "None" then
            local objective = TITLE_SOURCES[S.selectedTitle]
            if objective then
                if objective.type == "BossKills" or objective.type == "ItemDrops" then
                    for _, bName in ipairs(MAJOR_BOSSES) do
                        if checkBossAlive(bName) then targetMob = bName; break end
                    end
                elseif objective.type == "Boss" then
                    targetMob = objective.name
                end

                if not targetMob and S.hopForTitle then
                    if not char:GetAttribute("TitleHopDelay") then char:SetAttribute("TitleHopDelay", tick()) end
                    if tick() - char:GetAttribute("TitleHopDelay") > 5 then
                        print("[JOMHUB] No title bosses found. Hopping server...")
                        ServerHop()
                        task.wait(10)
                    end
                end
            end
        elseif S.autoDungeon and isInDungeon then
            targetMob = "Dungeon Mob" -- Placeholder name for logic
        elseif S.autoInfiniteTower and isInInfiniteTower then
            targetMob = "Tower Mob" -- Placeholder name for logic
        elseif S.autoSummon then
            local summonList = {}
            for k, v in pairs(S.summonTargets or {}) do if v then table.insert(summonList, k) end end
            table.sort(summonList)

            if #summonList > 0 then
                local cIdx = char:GetAttribute("SummonIdx") or 1
                if cIdx > #summonList then cIdx = 1 end
                char:SetAttribute("SummonIdx", cIdx)

                local bossToSummon = summonList[cIdx]
                
                local isAlive = checkBossAlive(bossToSummon)
                if isAlive then
                    char:SetAttribute("SummonIdx", cIdx + 1)
                    task.wait(1)
                    continue
                end

                local reqs = SUMMON_REQUIREMENTS[bossToSummon]
                local hasItems = true
                if reqs then
                    for item, amount in pairs(reqs) do
                        if not InventoryCache[item] or InventoryCache[item] < amount then
                            hasItems = false
                            break
                        end
                    end
                end

                if hasItems then
                    local portal = getPortalForMob(bossToSummon)
                    if portal and S.lastPortal ~= portal then
                        teleportToIsland(portal)
                        task.wait(3)
                        continue
                    end

                    if not char:GetAttribute("LastSummonAttempt") or tick() - char:GetAttribute("LastSummonAttempt") > 10 then
                        char:SetAttribute("LastSummonAttempt", tick())
                        print("[JOMHUB] Auto Summon: Attempting to summon " .. bossToSummon)
                        
                        local re = ReplicatedStorage:FindFirstChild("RemoteEvents")
                        local rem = ReplicatedStorage:FindFirstChild("Remotes")
                        local diff = S.summonDiff or "Normal"
                        
                        pcall(function()
                            if bossToSummon == "AtomicBoss" and re and re:FindFirstChild("RequestSpawnAtomic") then re.RequestSpawnAtomic:FireServer(diff)
                            elseif bossToSummon == "TrueAizenBoss" and re and re:FindFirstChild("RequestSpawnTrueAizen") then re.RequestSpawnTrueAizen:FireServer(diff)
                            elseif bossToSummon == "AnosBoss" and rem and rem:FindFirstChild("RequestSpawnAnosBoss") then rem.RequestSpawnAnosBoss:FireServer("Anos", diff)
                            elseif bossToSummon == "RimuruBoss" and re and re:FindFirstChild("RequestSpawnRimuru") then re.RequestSpawnRimuru:FireServer(diff)
                            elseif bossToSummon == "StrongestofTodayBoss" and rem and rem:FindFirstChild("RequestSpawnStrongestBoss") then rem.RequestSpawnStrongestBoss:FireServer("StrongestToday", diff)
                            elseif bossToSummon == "StrongestinHistoryBoss" and rem and rem:FindFirstChild("RequestSpawnStrongestBoss") then rem.RequestSpawnStrongestBoss:FireServer("StrongestHistory", diff)
                            elseif bossToSummon == "SaberBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("SaberBoss")
                            elseif bossToSummon == "QinShiBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("QinShiBoss")
                            elseif bossToSummon == "IchigoBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("IchigoBoss")
                            elseif bossToSummon == "GilgameshBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("GilgameshBoss", diff)
                            elseif bossToSummon == "BlessedMaidenBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("BlessedMaidenBoss", diff)
                            elseif bossToSummon == "SaberAlterBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("SaberAlterBoss", diff)
                            end
                        end)
                        char:SetAttribute("SummonIdx", cIdx + 1)
                    end
                else
                    char:SetAttribute("SummonIdx", cIdx + 1)
                end
            end
            targetMob = nil
        end

        if not targetMob or targetMob == "None" then 
            if char and char:FindFirstChild("HumanoidRootPart") then
                local fbv = char.HumanoidRootPart:FindFirstChild("JomFarmBV")
                if fbv then fbv:Destroy() end
            end
            task.wait(1)
            continue 
        end

        if not ((S.autoDungeon and isInDungeon) or (S.autoInfiniteTower and isInInfiniteTower)) then
            local requiredPortal = getPortalForMob(targetMob)
            
            if requiredPortal and S.lastPortal ~= requiredPortal then
                print("[JOMHUB] Attempting to teleport to:", requiredPortal)
                local success = teleportToIsland(requiredPortal)
                if success then
                    print("[JOMHUB] Successfully arrived and confirmed portal:", requiredPortal)
                    task.wait(1)
                else
                    print("[JOMHUB] Failed to confirm portal loading for:", requiredPortal)
                    task.wait(2)
                end
                continue
            end
        end
        
        -- Confirmed on the correct island, scan for enemies and tween!
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if not hrp or not hum then task.wait(1); continue end
        
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end

        local NPCsFolder = Workspace:FindFirstChild("NPCs")
        local minDist = math.huge
        local closest = nil
        
        if (S.autoDungeon and isInDungeon) or (S.autoInfiniteTower and isInInfiniteTower) then
            if NPCsFolder then
                for _, npc in ipairs(NPCsFolder:GetChildren()) do
                    local nHum = npc:FindFirstChild("Humanoid")
                    local nRoot = npc:FindFirstChild("HumanoidRootPart")
                    if nHum and nHum.Health > 0 and nRoot then
                        local d = (hrp.Position - nRoot.Position).Magnitude
                        if d < minDist then minDist = d; closest = npc end
                    end
                end
            end
        else
            if NPCsFolder then
                local cleanTarget = string.lower(string.gsub(targetMob, "%s+", ""))
                local strippedTarget = string.gsub(cleanTarget, "boss", "")
                for _, npc in ipairs(NPCsFolder:GetChildren()) do
                    local npcName = npc.Name:gsub("%d+$", "")
                    npcName = npcName:gsub("_.*", "")
                    local cleanNPC = string.lower(string.gsub(npcName, "%s+", ""))
                    if cleanNPC == cleanTarget or (cleanNPC == strippedTarget and npc:FindFirstChild("Humanoid") and npc.Humanoid.MaxHealth > 5000) then
                        local nHum = npc:FindFirstChild("Humanoid")
                        local nRoot = npc:FindFirstChild("HumanoidRootPart")
                        if nHum and nHum.Health > 0 and nRoot then
                            local d = (hrp.Position - nRoot.Position).Magnitude
                            if d < minDist then minDist = d; closest = npc end
                        end
                    end
                end
            end
        end
        
        if closest then
            if char then char:SetAttribute("BossLoadAttempts", 0) end
            if (S.autoSummonPity or S.autoHopPity) and not char:GetAttribute("TrackingPityFor") then
                char:SetAttribute("TrackingPityFor", closest.Name)
                local trackedNpc = closest
                
                local tHum = trackedNpc:FindFirstChild("Humanoid")
                if tHum then
                    local conn; conn = tHum.Died:Connect(function()
                        if S.autoSummonPity or S.autoHopPity then
                            if _G.JomHub_BossPity >= 24 then updatePity(0)
                            else updatePity(_G.JomHub_BossPity + 1) end
                        end
                        if char then char:SetAttribute("TrackingPityFor", nil) end
                        if conn then conn:Disconnect() end
                    end)
                end
            end
            local tRoot = closest:FindFirstChild("HumanoidRootPart")
            local tHum = closest:FindFirstChild("Humanoid")
            
            if tRoot and tHum then
                pcall(function() tHum.WalkSpeed = 0; tHum.JumpPower = 0; tRoot.CanCollide = false; tRoot.Velocity = Vector3.zero end)
                
                local farmPos = (S.autoDungeon and isInDungeon) and S.dungeonPos or S.farmPos
                local goalCF = getFarmPosition(tRoot, S.farmDistance, farmPos)
                if (hrp.Position - goalCF.Position).Magnitude > 50 then
                    local fbv = hrp:FindFirstChild("JomFarmBV")
                    if fbv then fbv:Destroy() end
                    SmartTeleport(goalCF)
                else
                    local fbv = hrp:FindFirstChild("JomFarmBV")
                    if not fbv then
                        fbv = Instance.new("BodyVelocity")
                        fbv.Name = "JomFarmBV"
                        fbv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                        fbv.Velocity = Vector3.zero
                        fbv.Parent = hrp
                    end
                    for _, v in ipairs(hrp:GetChildren()) do
                        if (v:IsA("BodyVelocity") and v.Name ~= "JomFarmBV" and v.Name ~= "JomTeleportBV") or v:IsA("BodyPosition") or v:IsA("LinearVelocity") or v:IsA("AlignPosition") then
                            v:Destroy()
                        end
                    end
                    if (hrp.Position - goalCF.Position).Magnitude > 5 then
                        hrp.CFrame = goalCF
                    end
                    hrp.Velocity = Vector3.zero
                    pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
                    
                    local weapons = getWeaponsToUse()
                    local loopWeapons = #weapons > 0 and weapons or {false}
                    for _, wep in ipairs(loopWeapons) do
                        if wep and typeof(wep) == "Instance" and wep.Parent ~= char then
                            pcall(function() hum:EquipTool(wep) end)
                            task.wait(0.05) -- brief delay needed for game to render tool handle locally
                        end
                        executeAttacks(closest, wep)
                    end
                end
            end
        else
            local fbv = hrp:FindFirstChild("JomFarmBV")
            if fbv then fbv:Destroy() end
            if char:GetAttribute("TrackingPityFor") then char:SetAttribute("TrackingPityFor", nil) end
            
            local isBoss = targetMob and string.find(string.lower(targetMob), "boss")
            if isBoss then
                local cleanBName = string.gsub(targetMob, "Boss", "")
                local cName = "TimedBossSpawn_" .. targetMob .. "_Container"
                local cName2 = "TimedBossSpawn_" .. cleanBName .. "_Container"
                local cont = Workspace:FindFirstChild(cName) or Workspace:FindFirstChild(cName2)
                if not cont and targetMob == "YamatoBoss" then cont = Workspace:FindFirstChild("TimedBossSpawn_Yamato_Container") end
                
                if cont then
                    local sp = cont:FindFirstChild("TimedBossSpawn_" .. targetMob) or cont
                    local spawnerPos = nil
                    if sp:IsA("Model") and sp.PrimaryPart then spawnerPos = sp:GetPivot().Position
                    elseif sp:IsA("Model") then local p = sp:FindFirstChildWhichIsA("BasePart", true); if p then spawnerPos = p.Position end
                    elseif sp:IsA("BasePart") then spawnerPos = sp.Position end
                    
                    if spawnerPos then
                        pcall(function() LocalPlayer:RequestStreamAroundAsync(spawnerPos) end)
                        if (hrp.Position - spawnerPos).Magnitude > 50 then 
                            SmartTeleport(CFrame.new(spawnerPos + Vector3.new(0, 15, 0))) 
                        else
                            hrp.Velocity = Vector3.zero
                        end
                    end
                end

                local isSummonable = {
                    ["AtomicBoss"]=true, ["TrueAizenBoss"]=true, ["AnosBoss"]=true, 
                    ["RimuruBoss"]=true, ["StrongestofTodayBoss"]=true, ["StrongestinHistoryBoss"]=true, 
                    ["SaberBoss"]=true, ["QinShiBoss"]=true, ["IchigoBoss"]=true, 
                    ["GilgameshBoss"]=true, ["BlessedMaidenBoss"]=true, ["SaberAlterBoss"]=true
                }
                
                if (S.autoSummonPity or S.autoHopPity) and isSummonable[targetMob] then
                        if not char:GetAttribute("LastPitySummon") or tick() - char:GetAttribute("LastPitySummon") > 8 then
                            char:SetAttribute("LastPitySummon", tick())
                            print("[JOMHUB] Summoning " .. targetMob .. "...")
                            
                            local re = ReplicatedStorage:FindFirstChild("RemoteEvents")
                            local rem = ReplicatedStorage:FindFirstChild("Remotes")
                            local diff = S.pitySummonDiff or "Normal"
                            
                            pcall(function()
                                if targetMob == "AtomicBoss" and re and re:FindFirstChild("RequestSpawnAtomic") then re.RequestSpawnAtomic:FireServer(diff)
                                elseif targetMob == "TrueAizenBoss" and re and re:FindFirstChild("RequestSpawnTrueAizen") then re.RequestSpawnTrueAizen:FireServer(diff)
                                elseif targetMob == "AnosBoss" and rem and rem:FindFirstChild("RequestSpawnAnosBoss") then rem.RequestSpawnAnosBoss:FireServer("Anos", diff)
                                elseif targetMob == "RimuruBoss" and re and re:FindFirstChild("RequestSpawnRimuru") then re.RequestSpawnRimuru:FireServer(diff)
                                elseif targetMob == "StrongestofTodayBoss" and rem and rem:FindFirstChild("RequestSpawnStrongestBoss") then rem.RequestSpawnStrongestBoss:FireServer("StrongestToday", diff)
                                elseif targetMob == "StrongestinHistoryBoss" and rem and rem:FindFirstChild("RequestSpawnStrongestBoss") then rem.RequestSpawnStrongestBoss:FireServer("StrongestHistory", diff)
                                elseif targetMob == "SaberBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("SaberBoss")
                                elseif targetMob == "QinShiBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("QinShiBoss")
                                elseif targetMob == "IchigoBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("IchigoBoss")
                                elseif targetMob == "GilgameshBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("GilgameshBoss", diff)
                                elseif targetMob == "BlessedMaidenBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("BlessedMaidenBoss", diff)
                                elseif targetMob == "SaberAlterBoss" and rem and rem:FindFirstChild("RequestSummonBoss") then rem.RequestSummonBoss:FireServer("SaberAlterBoss", diff)
                                end
                            end)
                            
                            if _G.JomHub_BossPity < 25 and not S.autoHopPity then
                                local cIdx = char:GetAttribute("PityBuilderIdx") or 1
                                char:SetAttribute("PityBuilderIdx", cIdx + 1)
                            end
                        end
                    end
            else
                if not targetQuest or targetQuest == "" then
                    for _, tier in ipairs(PROGRESSION_MAP) do
                        if tier.Mob == targetMob then
                            targetQuest = tier.Quest
                            break
                        end
                    end
                end

                if targetQuest and targetQuest ~= "" then
                    local questNPC = Workspace:FindFirstChild(targetQuest) or (Workspace:FindFirstChild("ServiceNPCs") and Workspace.ServiceNPCs:FindFirstChild(targetQuest))
                    if questNPC and questNPC:IsA("Model") then
                        local qPos = questNPC:GetPivot().Position
                        pcall(function() LocalPlayer:RequestStreamAroundAsync(qPos) end)
                        if (hrp.Position - qPos).Magnitude > 50 then
                            SmartTeleport(CFrame.new(qPos + Vector3.new(0, 15, -20)))
                        else
                            hrp.Velocity = Vector3.zero
                        end
                    end
                end
            end
            task.wait(0.5) -- Wait briefly for respawns if no targets found
        end
    end
end)

