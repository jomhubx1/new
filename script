    end

    function Elements:CreateButton(title, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 45)
        btn.BackgroundColor3 = C.ElementBG
        btn.Text = ""
        btn.AutoButtonColor = false
        btn.Parent = Page
        
        local lbl = createLabel(btn, title, Enum.TextXAlignment.Center, Enum.Font.GothamBold, 13, C.Text)
        lbl.Size = UDim2.new(1, 0, 1, 0)
        
        btn.MouseEnter:Connect(function() btn.BackgroundColor3 = C.ElementHover end)
        btn.MouseLeave:Connect(function() btn.BackgroundColor3 = C.ElementBG end)
        
        btn.Activated:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.Accent}):Play()
            task.delay(0.1, function() TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.ElementHover}):Play() end)
            if callback then callback() end
        end)
        return btn
    end

    return Elements
end

