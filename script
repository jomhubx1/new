local function ServerHop()
    task.spawn(function()
        math.randomseed(tick())
        local sfUrl = "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100"
        local success, req = pcall(function() return request({Url = string.format(sfUrl, game.PlaceId)}) end)
        if success and req and req.Body then
            local s2, body = pcall(function() return HttpService:JSONDecode(req.Body) end)
            if s2 and body and body.data then
                local validServers = {}
                for _, s in ipairs(body.data) do
                    if type(s) == "table" and s.playing and s.maxPlayers and s.playing < (s.maxPlayers - 1) and s.id ~= game.JobId then
                        table.insert(validServers, s)
                    end
                end
                if #validServers > 0 then
                    for i = #validServers, 2, -1 do
                        local j = math.random(1, i)
                        validServers[i], validServers[j] = validServers[j], validServers[i]
                    end

                    for _, serverToJoin in ipairs(validServers) do
                        pcall(function() game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, serverToJoin.id, LocalPlayer) end)
                        task.wait(1.5) -- Give the teleport a moment to fire
                        return
                    end
                end
            end
        end
        -- Fallback for mobile executors if API request fails or gets rate-limited
        pcall(function() game:GetService("TeleportService"):Teleport(game.PlaceId, LocalPlayer) end)
    end)
end

