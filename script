local function getPortalForMob(mobName)
    if not mobName or mobName == "" then return nil end
    local cleanName = string.lower(string.gsub(mobName:gsub("%d+$", ""), "%s+", ""))
    return PORTAL_MAP[cleanName] or "Starter"
end

local function checkBossAlive(bName)
    local NPCsFolder = Workspace:FindFirstChild("NPCs")
    if NPCsFolder then
        local cleanTarget = string.lower(string.gsub(bName, "%s+", ""))
        local strippedTarget = string.gsub(cleanTarget, "boss", "")
        for _, npc in ipairs(NPCsFolder:GetChildren()) do
            local npcName = npc.Name:gsub("%d+$", "")
            npcName = npcName:gsub("_.*", "")
            local cleanNPC = string.lower(string.gsub(npcName, "%s+", ""))
            if cleanNPC == cleanTarget then
                local hum = npc:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then return true end
            elseif cleanNPC == strippedTarget then
                local hum = npc:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 and hum.MaxHealth > 5000 then return true end
            end
        end
    end
    return false
end

local function teleportToIsland(portalName)
    if not portalName or portalName == "" then return false end
    if S.lastPortal == portalName then return true end

    local folderName = ISLAND_FOLDERS[portalName] or (portalName .. "Island")
    
    if TeleportToPortal then
        pcall(function() TeleportToPortal:FireServer(portalName) end)
    end

    local t = tick()
    local portalLoaded = false
    while tick() - t < 10 do -- 10 seconds timeout for island rendering
        local islandFolder = Workspace:FindFirstChild(folderName)
        if islandFolder then
            local portalPart = islandFolder:FindFirstChild("Portal_" .. portalName)
            if portalPart then
                portalLoaded = true
                break
            end
        end
        task.wait(0.2)
    end

    if portalLoaded then
        S.lastPortal = portalName
        task.wait(1) -- small buffer after portal renders
        return true
    else
        S.lastPortal = "" -- Reset if failed so it can try again
        return false
    end
end

local function getFarmPosition(targetRoot, baseDistance, posType)
    local enemyPos = targetRoot.Position
    if posType == "Above" then 
        local tpPos = enemyPos + Vector3.new(0, baseDistance, 0)
        return CFrame.new(tpPos) * CFrame.Angles(math.rad(-90), 0, 0)
    else
        local behindPos = (targetRoot.CFrame * CFrame.new(0, 0, baseDistance)).Position
        return CFrame.lookAt(behindPos, enemyPos)
    end
end

local function SmartTeleport(targetCFrame)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local dungeonIds = { [75159314259063] = true, [99684056491472] = true, [123955125827131] = true, [96767841099256] = true }
    local isInDungeon = dungeonIds[game.PlaceId]
    local isInInfiniteTower = (game.PlaceId == 138368689293913)
    local useInstantInDungeon = (S.autoDungeon and isInDungeon) or (S.autoInfiniteTower and isInInfiniteTower)

    if useInstantInDungeon then
        hrp.CFrame = targetCFrame
        pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
        return
    end

    local dist = (hrp.Position - targetCFrame.Position).Magnitude
    if dist < 50 then 
        hrp.CFrame = targetCFrame
        return 
    end

    local speed = 150
    local timeToReach = math.max(0.1, dist / speed)
    
    local bv = hrp:FindFirstChild("JomTeleportBV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "JomTeleportBV"
        bv.Velocity = Vector3.zero
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Parent = hrp
    end

    local tweenInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    
    tween:Play()
    
    local t = tick()
    while tween.PlaybackState == Enum.PlaybackState.Playing do
        if not (S.AutoFarmActive or S.AutoLevelActive or S.AutoBossActive or S.AutoAllBossActive or S.autoSummonPity or S.autoHopPity or S.autoDungeon or S.autoInfiniteTower or S.autoFarmTitle or S.autoFarmItems or S.autoSummon) or (tick() - t > timeToReach + 1) then
            tween:Cancel()
            break
        end
        task.wait()
    end
    
    if bv then bv:Destroy() end
end

