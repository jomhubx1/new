local function parseLevel(val)
    if type(val) == "number" then return val end
    if type(val) == "string" then
        local num = string.match(val, "%d+")
        if num then return tonumber(num) end
    end
    return 1
end

local function getCurrentLevel()
    local data = LocalPlayer:FindFirstChild("Data")
    if data and data:FindFirstChild("Level") then return parseLevel(data.Level.Value) end
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats and leaderstats:FindFirstChild("Level") then return parseLevel(leaderstats.Level.Value) end
    if LocalPlayer:GetAttribute("Level") then return parseLevel(LocalPlayer:GetAttribute("Level")) end
    return 1
end

