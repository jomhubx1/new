local function parseLevel(val)
    if type(val) == "number" then return val end
    if type(val) == "string" then
        local num = string.match(val, "%d+")
        if num then return tonumber(num) end
    end
    return 1
end

local function getCurrentLevel()
    local data = LocalPlayer:FindFirstChild("Data")
    if data and data:FindFirstChild("Level") then return parseLevel(data.Level.Value) end
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats and leaderstats:FindFirstChild("Level") then return parseLevel(leaderstats.Level.Value) end
    if LocalPlayer:GetAttribute("Level") then return parseLevel(LocalPlayer:GetAttribute("Level")) end
    return 1
end

local function SmartTeleport(targetCFrame)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then return end
    
    local dist = (hrp.Position - targetCFrame.Position).Magnitude
    if dist < 50 then hrp.CFrame = targetCFrame; return end
    
    if S.teleportMode == "Instant" then
        hrp.CFrame = targetCFrame
        return
    end
    
    local speed = 150
    local timeToReach = math.max(0.1, dist / speed)
    
    local fbv = hrp:FindFirstChild("JomFarmBV")
    if fbv then fbv:Destroy() end
    
    local bv = hrp:FindFirstChild("JomTeleportBV")
    if not bv then
		bv = Instance.new("LinearVelocity")
		bv.Name = "JomTeleportBV"; bv.VectorVelocity = Vector3.zero; bv.MaxForce = math.huge; bv.RelativeTo = Enum.ActuatorRelativeTo.World; bv.Attachment0 = hrp:FindFirstChildOfClass("Attachment") or Instance.new("Attachment", hrp); bv.Parent = hrp
    end
    
    local tweenInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    
    local conn = RunService.Heartbeat:Connect(function()
        if not (S.AutoLevelActive or S.AutoFarmActive or S.autoHuntBoss) or not char or hum.Health <= 0 then tween:Cancel() end
    end)
    
    tween:Play()
    local startTick = tick()
    while tween.PlaybackState == Enum.PlaybackState.Playing do
        if tick() - startTick > timeToReach + 2 then tween:Cancel(); break end
        task.wait()
    end
    if conn then conn:Disconnect() end
    if bv then bv:Destroy() end
end

local function getFarmPosition(targetRoot, baseDistance, posType)
    local enemyPos = targetRoot.Position
    local tpPos = enemyPos
    
    if posType == "Above" then 
        tpPos = enemyPos + Vector3.new(0, baseDistance, 0)
        return CFrame.new(tpPos) * CFrame.Angles(math.rad(-90), 0, 0)
    else
        local lookVec = targetRoot.CFrame.LookVector
        local angle = math.atan2(-lookVec.X, -lookVec.Z)
        local flatCF = CFrame.new(enemyPos) * CFrame.Angles(0, angle, 0)
        
        tpPos = (flatCF * CFrame.new(0, 0, baseDistance)).Position
        return CFrame.lookAt(tpPos, enemyPos)
    end
end

